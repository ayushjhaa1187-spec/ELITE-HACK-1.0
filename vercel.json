{
    "version": 2,
    "functions": {
        "api/index.ts": {
            "includeFiles": "prisma/**,swagger.yaml,public/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/api-docs(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.ts"
        }
    ]
}