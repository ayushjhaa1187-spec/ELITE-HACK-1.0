{
    "version": 2,
    "functions": {
        "api/server.ts": {
            "includeFiles": "prisma/**,swagger.yaml,public/**"
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/server.ts"
        },
        {
            "src": "/api-docs(.*)",
            "dest": "/api/server.ts"
        },
        {
            "src": "/dashboard",
            "dest": "/api/server.ts"
        },
        {
            "src": "/(.*)",
            "dest": "/api/server.ts"
        }
    ]
}